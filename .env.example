# 🔐 BACKEND NODE.JS — 224SOLUTIONS — EXEMPLE (placeholders uniquement)
# ⚠️ NE JAMAIS COMMITTER DE VRAIES VALEURS DANS CE FICHIER.
# ⚠️ Ce fichier contenait auparavant de VRAIES clés Supabase (dont service_role) :
#    elles sont donc COMPROMISES → les RÉVOQUER/ROTER dans Supabase immédiatement.

# ── Serveur ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Scaling horizontal (ECS Fargate) : 'false' sur les conteneurs WEB (N instances),
# 'true' sur l'UNIQUE worker (jobs + surveillance). Défaut 'true' = comportement actuel.
RUN_BACKGROUND_JOBS=true

# ── Supabase (PostgreSQL + Auth + Storage) ───────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# ⚠️ service_role = accès TOTAL (bypass RLS). Jamais exposé au frontend, jamais commité.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Connexion directe (migrations) — TOUJOURS via le pooler Supavisor port 6543 (mode transaction)
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ── Auth / secrets internes ──────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
INTERNAL_API_KEY=your-internal-api-key-min-16-chars
TRANSACTION_SECRET_KEY=
CCP_ENCRYPTION_KEY=

# ── 2FA admin (step-up TOTP serveur sur les ops financières sensibles) ────
# 'false' (défaut) = transition non-bloquante : un admin SANS 2FA garde l'accès (avertissement
# loggé), le temps que tous enrôlent. Passer à 'true' une fois enrôlés → 2FA EXIGÉE.
# PROCÉDURE D'ACTIVATION : 1) chaque admin enrôle son TOTP via POST /api/v2/admin/mfa/setup ;
# 2) vérifier is_mfa_enrolled=true pour tous les admins/pdg/ceo ; 3) passer à true + redéployer.
ADMIN_MFA_ENFORCED=false
# Clé de chiffrement du secret TOTP au repos. Si absente → repli sur CCP_ENCRYPTION_KEY /
# TRANSACTION_SECRET_KEY / JWT_SECRET. Recommandé : 32+ caractères aléatoires dédiés.
MFA_ENCRYPTION_KEY=

# ── Redis (Upstash) — cache + rate-limiting partagé + locks distribués ────
# rediss:// = TLS. Définir REDIS_URL active Redis automatiquement.
REDIS_URL=rediss://default:PASSWORD@YOUR-ENDPOINT.upstash.io:6379
REDIS_ENABLED=
# (Fallback host/port séparés si Redis auto-hébergé)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Temps réel : Ably (géoloc live + analytics live) ─────────────────────
# Active Ably côté backend (signature des tokens via /api/v2/realtime/token).
ABLY_API_KEY=your-ably-api-key

# ── Rate limiting (limiteur GLOBAL par IP, partagé via Redis) ────────────
# Défauts réalistes (1 page web = plusieurs appels API). Les routes sensibles
# (login, SMS, paiement) ont en plus des limites dédiées via routeRateLimiter.
RATE_LIMIT_WINDOW_MS=60000
# Défaut : 300/min = 5 req/s par IP (filet anti brute-force). Augmenter si des clients
# légitimes sont bloqués (ex: 600 pour API B2B). Routes sensibles = limites propres en plus.
RATE_LIMIT_MAX_REQUESTS=300

# ── CORS (domaines autorisés, séparés par des virgules) ──────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://224solution.net

# ── Stockage fichiers : Google Cloud Storage ─────────────────────────────
GCS_BUCKET=224solutions
GCS_PROJECT_ID=
# Clé de service (chemin du fichier JSON OU contenu base64)
GOOGLE_APPLICATION_CREDENTIALS=
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ── Notifications push : Firebase FCM ────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── SMS : Twilio ─────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID/AUTH_TOKEN servent AUSSI au TURN des appels WebRTC (Network Traversal,
# même compte que les SMS, aucune ressource à créer — facturé à la bande passante relayée).
# Twilio est le FILET : la passerelle bascule dessus si Orange n'est pas configuré pour le pays.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# ── SMS : Orange (multi-pays) ────────────────────────────────────────────
# Guide complet (où trouver chaque valeur, souscrire un pays, acheter un bundle,
# demander un sender name) : docs/SMS_ORANGE_CONFIGURATION.md
#
# 1) IDENTIFIANTS GLOBAUX — UNE SEULE application Orange Developer, TOUS pays confondus.
#    MyApps → votre application → « Client ID » / « Client Secret ». Identiques pour GN, SN, …
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_SMS_ENABLED=true
# Seuil d'alerte solde bas (unités SMS restantes) → alerte PDG sous ce seuil. Défaut 100.
ORANGE_SMS_LOW_BALANCE_THRESHOLD=100
#
# 2) PAR PAYS — ne remplir QUE les pays SOUSCRITS & APPROUVÉS. Ajouter un pays =
#    remplir ces 3 lignes + redémarrer. AUCUN code à modifier.
#    _SENDER_ADDRESS = la SIM Orange du pays au format tel:+<indicatif><numéro>.
#    _SENDER_NAME    = expéditeur alphanumérique (obligatoire dans certains pays depuis juin 2026).
#
# Guinée Conakry (+224) — APPROUVÉ
ORANGE_SMS_GN_ENABLED=true
ORANGE_SMS_GN_SENDER_ADDRESS=tel:+224XXXXXXXXX
ORANGE_SMS_GN_SENDER_NAME=224Solutions
# Sénégal (+221) — EN ATTENTE de validation
ORANGE_SMS_SN_ENABLED=false
ORANGE_SMS_SN_SENDER_ADDRESS=
ORANGE_SMS_SN_SENDER_NAME=224Solutions
# Mali (+223)
ORANGE_SMS_ML_ENABLED=false
ORANGE_SMS_ML_SENDER_ADDRESS=
ORANGE_SMS_ML_SENDER_NAME=224Solutions
# Côte d'Ivoire (+225)
ORANGE_SMS_CI_ENABLED=false
ORANGE_SMS_CI_SENDER_ADDRESS=
ORANGE_SMS_CI_SENDER_NAME=224Solutions
# Burkina Faso (+226)
ORANGE_SMS_BF_ENABLED=false
ORANGE_SMS_BF_SENDER_ADDRESS=
ORANGE_SMS_BF_SENDER_NAME=224Solutions
# Niger (+227)
ORANGE_SMS_NE_ENABLED=false
ORANGE_SMS_NE_SENDER_ADDRESS=
ORANGE_SMS_NE_SENDER_NAME=224Solutions
# Cameroun (+237)
ORANGE_SMS_CM_ENABLED=false
ORANGE_SMS_CM_SENDER_ADDRESS=
ORANGE_SMS_CM_SENDER_NAME=224Solutions
# RD Congo (+243)
ORANGE_SMS_CD_ENABLED=false
ORANGE_SMS_CD_SENDER_ADDRESS=
ORANGE_SMS_CD_SENDER_NAME=224Solutions
# Guinée-Bissau (+245)
ORANGE_SMS_GW_ENABLED=false
ORANGE_SMS_GW_SENDER_ADDRESS=
ORANGE_SMS_GW_SENDER_NAME=224Solutions
# Botswana (+267)
ORANGE_SMS_BW_ENABLED=false
ORANGE_SMS_BW_SENDER_ADDRESS=
ORANGE_SMS_BW_SENDER_NAME=224Solutions
# Égypte (+20)
ORANGE_SMS_EG_ENABLED=false
ORANGE_SMS_EG_SENDER_ADDRESS=
ORANGE_SMS_EG_SENDER_NAME=224Solutions
# Tunisie (+216)
ORANGE_SMS_TN_ENABLED=false
ORANGE_SMS_TN_SENDER_ADDRESS=
ORANGE_SMS_TN_SENDER_NAME=224Solutions

# ── Email : Resend / SMTP ────────────────────────────────────────────────
RESEND_API_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Dropshipping : connecteurs fournisseurs (clés SERVEUR, jamais au front) ──
# Définir les clés active le PLACEMENT RÉEL des commandes chez le fournisseur ;
# sinon le placement reste en MODE MOCK (commande simulée, l'orchestration marche).
ALIEXPRESS_API_KEY=
ALIEXPRESS_API_SECRET=
ALIEXPRESS_ACCESS_TOKEN=
ALIEXPRESS_API_URL=https://api.aliexpress.com/v2
ALIBABA_API_KEY=
ALIBABA_API_SECRET=
ALIBABA_API_URL=https://api.alibaba.com/openapi
ONE688_API_KEY=
ONE688_API_SECRET=
ONE688_API_URL=https://gw.open.1688.com/openapi
PRIVATE_SUPPLIER_API_KEY=
PRIVATE_SUPPLIER_API_URL=
# Intervalle de la sync prix/stock dropship (worker uniquement). Défaut 30 min.
DROPSHIP_SYNC_INTERVAL_MS=1800000

# ── Paiements ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_SECRET=
DJOMY_CLIENT_SECRET=

# ── OAuth ────────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# ── IA — Copilot 224 (priorité : Anthropic > Lovable > OpenAI ; sinon repli) ──
ANTHROPIC_API_KEY=        # Claude (recommandé) — sk-ant-...
LOVABLE_API_KEY=          # LEGACY passerelle Gemini — utilisée UNIQUEMENT par le copilot (vision) + génération d'image produit. La TRADUCTION (messages/vocaux) n'en dépend PLUS (voir aiTranslate.service : Anthropic haiku → OpenAI). À retirer quand le copilot migre (mission Copilote 224). translate-product = seul edge translate-* restant à migrer.
OPENAI_API_KEY=           # GPT (optionnel) — repli vision (gpt-4o-mini) si LOVABLE absent

# ── Jobs / monitoring / logs ─────────────────────────────────────────────
ENABLE_CRON_JOBS=true
ENABLE_MONITORING=true
# Auto-réparation : diagnostic dual-IA (OpenAI→Claude) auto à chaque cycle 24/7 (sans clic PDG).
# Ne diagnostique que les NOUVEAUX incidents (dédupliqués) → coût LLM borné. 'false' = à la demande.
AUTO_HEALING_ENABLED=false
# Fréquence du scan RÉSEAU sécurité-frontend (lourd) dans le cycle 24/7. Défaut 30 min : les cycles
# 60s restent rapides (domaines DB), le scan complet ne tourne qu'au démarrage puis à cet intervalle.
FRONTEND_SCAN_INTERVAL_MS=1800000
LOG_LEVEL=info
LOG_FILE=./logs/backend.log

# ============================================================================
# FRONTEND (Vite) — variables VITE_* (dans le .env du frontend, jamais de secret serveur !)
#   VITE_REALTIME_PROVIDER=ably        # bascule géoloc/analytics temps réel sur Ably
#   VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY (anon uniquement — jamais service_role)
#   VITE_FIREBASE_* (config FCM publique)
# CDN : Cloudflare se configure côté DNS/proxy (pas de variable backend).
# ============================================================================

# ── PayPal (paiements) ────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id   # Dashboard PayPal → Webhooks → Webhook ID
